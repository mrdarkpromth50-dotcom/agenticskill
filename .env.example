# Environment variables for Agentic Company System

# OpenClaw Gateway
OPENCLAW_API_KEY=your-openclaw-api-key
OPENCLAW_API_SECRET=your-openclaw-api-secret

# Discord Integration
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-guild-id

# Telegram Integration  
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Memory System
REDIS_URL=redis://localhost:6379
VECTOR_DB_URL=http://localhost:8000
VECTOR_DB_TYPE=chromadb

# Translation Layer
TRANSLATION_MODE=llm
TRANSLATION_MODEL=gemini-3-flash

# Persistent Agent Layer
PERSISTENT_AGENT_HEARTBEAT_INTERVAL=30000
PERSISTENT_AGENT_AUTO_RESTART=true

# Spawn Manager
SPAWN_MAX_CONCURRENT=10
SPAWN_TASK_TIMEOUT=3600000

# Account Rotation
ACCOUNT_ROTATION_ENABLED=true
ACCOUNT_ROTATION_STRATEGY=round-robin
ACCOUNT_HEALTH_CHECK_INTERVAL=60000

# LLM Accounts (เพิ่มได้ถึง 20 บัญชี)
GOOGLE_ACCOUNT_1_EMAIL=account1@gmail.com
GOOGLE_ACCOUNT_1_PASSWORD=app-password-1
GOOGLE_ACCOUNT_2_EMAIL=account2@gmail.com
GOOGLE_ACCOUNT_2_PASSWORD=app-password-2
# ... (สามารถเพิ่มได้ถึง GOOGLE_ACCOUNT_20_EMAIL/PASSWORD)
