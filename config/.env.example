# ===================================
# Agentic Company - Environment Config
# ===================================

# --- Antigravity Proxy ---
PROXY_HOST=192.168.80.1
PROXY_PORT=8080
PROXY_API_KEY=proxy-key

# --- OpenClaw Gateway ---
OPENCLAW_PORT=18789
OPENCLAW_CONFIG_PATH=/home/donla/.openclaw/openclaw.json

# --- LLM Models (ผ่าน Antigravity Proxy) ---
# Primary: antigravity-proxy/gemini-3.1-pro-high
# Available Models:
#   - gemini-3.1-pro-high    (Gemini 3.1 Pro High - reasoning)
#   - claude-opus-4-6-thinking (Claude Opus 4.6 Thinking - reasoning)
#   - gemini-2.5-pro         (Gemini 2.5 Pro - reasoning)
#   - gemini-3.1-pro-low     (Gemini 3.1 Pro Low)
#   - claude-sonnet-4-6      (Claude Sonnet 4.6)
#   - gemini-3-pro-high      (Gemini 3 Pro High - reasoning)
#   - gemini-3-pro-low       (Gemini 3 Pro Low)
#   - gemini-3-flash         (Gemini 3 Flash)
#   - gemini-3-flash-agent   (Gemini 3 Flash Agent)
#   - gemini-3.1-flash-image (Gemini 3.1 Flash Image)
#   - gemini-3.1-flash-lite  (Gemini 3.1 Flash Lite)
#   - gemini-2.5-flash       (Gemini 2.5 Flash)
#   - gemini-2.5-flash-thinking (Gemini 2.5 Flash Thinking - reasoning)
#   - gemini-2.5-flash-lite  (Gemini 2.5 Flash Lite)

# --- Discord Integration ---
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-guild-id

# --- Telegram Integration ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-boss-chat-id

# --- Memory System ---
REDIS_URL=redis://localhost:6379
VECTOR_DB_URL=http://localhost:8000
VECTOR_DB_TYPE=chromadb

# --- Translation Layer ---
# Mode: llm (ใช้ LLM แปล) หรือ api (ใช้ Google Translate API)
TRANSLATION_MODE=llm
TRANSLATION_MODEL=gemini-3-flash

# --- Persistent Agent Layer ---
PERSISTENT_AGENT_HEARTBEAT_INTERVAL=30000
PERSISTENT_AGENT_AUTO_RESTART=true

# --- Spawn Manager ---
SPAWN_MAX_CONCURRENT=10
SPAWN_TASK_TIMEOUT=3600000

# --- LLM Account Rotation ---
ACCOUNT_ROTATION_ENABLED=true
ACCOUNT_ROTATION_STRATEGY=round-robin
ACCOUNT_HEALTH_CHECK_INTERVAL=60000

# LLM Google Accounts (เพิ่มได้ถึง 20 บัญชี)
GOOGLE_ACCOUNT_1_EMAIL=account1@gmail.com
GOOGLE_ACCOUNT_1_APP_PASSWORD=app-password-1
GOOGLE_ACCOUNT_2_EMAIL=account2@gmail.com
GOOGLE_ACCOUNT_2_APP_PASSWORD=app-password-2
# ... เพิ่มได้ถึง GOOGLE_ACCOUNT_20_EMAIL / GOOGLE_ACCOUNT_20_APP_PASSWORD

# --- Agent Model Assignment ---
# CEO, CTO, CSO ใช้ gemini-3.1-pro-high (reasoning สูงสุด)
# Agent ที่ต้องการ deep thinking ใช้ claude-opus-4-6-thinking
# Agent ทั่วไป ใช้ gemini-3-flash หรือ gemini-3.1-flash-lite (ประหยัด token)
CEO_MODEL=antigravity-proxy/gemini-3.1-pro-high
CTO_MODEL=antigravity-proxy/gemini-3.1-pro-high
CMO_MODEL=antigravity-proxy/gemini-3-pro-high
CSO_MODEL=antigravity-proxy/gemini-3.1-pro-high
ACCOUNTANT_MODEL=antigravity-proxy/gemini-3-flash
DEVOPS_MODEL=antigravity-proxy/gemini-3-pro-high
DEV_LEAD_MODEL=antigravity-proxy/gemini-3.1-pro-high
SPAWN_DEFAULT_MODEL=antigravity-proxy/gemini-3-flash
REASONING_MODEL=antigravity-proxy/claude-opus-4-6-thinking
