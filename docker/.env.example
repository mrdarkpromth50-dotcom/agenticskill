# --- Discord Configuration (for CEO Agent) ---
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
DISCORD_GUILD_ID=YOUR_DISCORD_GUILD_ID
DISCORD_CHANNEL_ID=YOUR_DISCORD_CHANNEL_ID

# --- Telegram Configuration (for CEO Agent) ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# --- Memory System Configuration ---
REDIS_URL=redis://redis:6379
VECTOR_DB_URL=http://chromadb:8000
VECTOR_DB_TYPE=chromadb # or other types if supported

# --- Persistent Agent Layer Configuration ---
PERSISTENT_AGENT_HEARTBEAT_INTERVAL=30000 # milliseconds (e.g., 30 seconds)
PERSISTENT_AGENT_AUTO_RESTART=true

# --- Spawn Manager Configuration ---
SPAWN_MAX_CONCURRENT=5
SPAWN_TASK_TIMEOUT=300000 # milliseconds (e.g., 5 minutes)

# --- Translation Layer Configuration ---
TRANSLATION_API_URL=http://ollama:11434/api/generate # Example: Ollama endpoint
TRANSLATION_MODEL=llama3 # Example: Model to use with Ollama

# --- Account Manager Configuration ---
# LLM_ACCOUNTS=[] # This will be managed via API, not directly in .env
ACCOUNT_ROTATION_INTERVAL=60000 # milliseconds (e.g., 1 minute)
LLM_ACCOUNT_HEALTH_CHECK_INTERVAL=300000 # milliseconds (e.g., 5 minutes)

# --- Inter-service Communication URLs ---
MEMORY_SYSTEM_URL=http://memory-system:3001
SPAWN_MANAGER_URL=http://spawn-manager:3003
TRANSLATION_LAYER_URL=http://translation-layer:3005
ACCOUNT_MANAGER_URL=http://account-manager:3006

# --- Service Ports (Internal to Docker, exposed ports are in docker-compose.yml) ---
MEMORY_SYSTEM_PORT=3001
PERSISTENT_AGENT_LAYER_PORT=3002
SPAWN_MANAGER_PORT=3003
CEO_AGENT_PORT=3004
TRANSLATION_LAYER_PORT=3005
ACCOUNT_MANAGER_PORT=3006

# --- Database/Cache Ports ---
REDIS_PORT=6379
CHROMADB_PORT=8000
OLLAMA_PORT=11434 # If using Ollama for translation
