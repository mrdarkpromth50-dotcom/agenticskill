# ==============================================================================
# AgenticSkill Environment Variables Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# Global Settings
# ------------------------------------------------------------------------------
# API_KEYS: Comma-separated list of API keys for inter-service authentication.
#           Each service will validate incoming requests against these keys.
API_KEYS=your_api_key_1,your_api_key_2

# RATE_LIMIT_MAX: Maximum number of requests allowed within the RATE_LIMIT_WINDOW.
RATE_LIMIT_MAX=100

# RATE_LIMIT_WINDOW: Time window in milliseconds for rate limiting.
RATE_LIMIT_WINDOW=60000

# ------------------------------------------------------------------------------
# Core Infrastructure Services
# ------------------------------------------------------------------------------
# REDIS_URL: Connection URL for the Redis instance (Short-term & Shared Memory).
REDIS_URL=redis://redis:6379

# VECTOR_DB_URL: Connection URL for the Vector Database (Long-term Memory).
VECTOR_DB_URL=http://chromadb:8000

# VECTOR_DB_TYPE: Type of Vector Database used (e.g., chromadb).
VECTOR_DB_TYPE=chromadb

# OLLAMA_URL: URL for the local Ollama LLM server.
OLLAMA_URL=http://ollama:11434

# ------------------------------------------------------------------------------
# Gateway & Proxy Services
# ------------------------------------------------------------------------------
# ANTIGRAVITY_PROXY_URL: Internal URL for the Antigravity Proxy service.
ANTIGRAVITY_PROXY_URL=http://antigravity-proxy:8080

# OPENCLAW_URL: Internal URL for the OpenClaw Gateway service.
OPENCLAW_URL=http://openclaw:18789

# Antigravity Proxy (BCProxyAI) Configuration
# LLM_PROVIDERS: Comma-separated list of LLM providers configuration.
#                Format: type:model:apiKey:baseUrl:priority
#                Example: gemini:gemini-pro:YOUR_GEMINI_API_KEY:https://generativelanguage.googleapis.com/v1beta:1
LLM_PROVIDERS=gemini:gemini-pro:YOUR_GEMINI_API_KEY:https://generativelanguage.googleapis.com/v1beta:1,openai:gpt-4:YOUR_OPENAI_API_KEY:https://api.openai.com/v1:2,ollama:llama2:none:http://ollama:11434/api:3

# PRIMARY_PROVIDER: Identifier for the primary LLM provider (e.g., gemini-gemini-pro).
PRIMARY_PROVIDER=gemini-gemini-pro

# FALLBACK_PROVIDERS: Comma-separated list of fallback LLM providers.
FALLBACK_PROVIDERS=openai-gpt-4,ollama-llama2

# FALLBACK_STRATEGY: Strategy for fallback (priority or random).
FALLBACK_STRATEGY=priority

# FALLBACK_MAX_RETRIES: Maximum retries for fallback providers.
FALLBACK_MAX_RETRIES=3

# FALLBACK_INITIAL_RETRY_DELAY: Initial delay in milliseconds before retrying with a fallback provider.
FALLBACK_INITIAL_RETRY_DELAY=1000

# GOOGLE_ACCOUNTS: Comma-separated list of Google account credentials for Gemini.
#                  Format: providerId:credentials
GOOGLE_ACCOUNTS=gemini-gemini-pro:YOUR_GOOGLE_KEY_1,gemini-gemini-pro:YOUR_GOOGLE_KEY_2

# LOAD_BALANCE_STRATEGY: Strategy for load balancing LLM requests (round-robin, least-used, random).
LOAD_BALANCE_STRATEGY=round-robin

# ------------------------------------------------------------------------------
# Service Port Definitions (Internal to Docker Network)
# These ports are used for inter-service communication within the Docker network.
# Exposed ports to the host are configured in docker-compose.yml.
# ------------------------------------------------------------------------------
MEMORY_SYSTEM_PORT=3001
PERSISTENT_AGENT_LAYER_PORT=3002
SPAWN_MANAGER_PORT=3003
CEO_AGENT_PORT=3004
TRANSLATION_LAYER_PORT=3005
ACCOUNT_MANAGER_PORT=3006
SPAWN_AGENTS_PORT=3007
MONITORING_PORT=3008
ACCOUNTANT_AGENT_PORT=3009
CTO_AGENT_PORT=3010
CMO_AGENT_PORT=3011
CSO_AGENT_PORT=3012
DEVOPS_AGENT_PORT=3013

# ------------------------------------------------------------------------------
# CEO Agent Service Configuration
# ------------------------------------------------------------------------------
# DISCORD_BOT_TOKEN: Discord bot token for CEO communication.
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN

# DISCORD_GUILD_ID: Discord guild (server) ID.
DISCORD_GUILD_ID=YOUR_DISCORD_GUILD_ID

# DISCORD_CHANNEL_ID: Discord channel ID for CEO reports and commands.
DISCORD_CHANNEL_ID=YOUR_DISCORD_CHANNEL_ID

# TELEGRAM_BOT_TOKEN: Telegram bot token for CEO communication.
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# TELEGRAM_CHAT_ID: Telegram chat ID for CEO reports and commands.
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# TREND_RESEARCH_INTERVAL: Interval in milliseconds for proactive trend research loop (default: 6 hours).
TREND_RESEARCH_INTERVAL=21600000

# DAILY_REPORT_CRON: Cron string for daily report generation (default: 6 PM daily, e.g., "0 18 * * *").
DAILY_REPORT_CRON="0 18 * * *"

# IDLE_CHECK_INTERVAL: Interval in milliseconds for idle check loop (default: 30 minutes).
IDLE_CHECK_INTERVAL=1800000

# DISCORD_REPORT_WEBHOOK_URL: Discord webhook URL for sending daily reports.
DISCORD_REPORT_WEBHOOK_URL=

# TELEGRAM_REPORT_CHAT_ID: Telegram chat ID for sending daily reports.
TELEGRAM_REPORT_CHAT_ID=

# ------------------------------------------------------------------------------
# Accountant Agent Service Configuration
# ------------------------------------------------------------------------------
# BANK_API_URL: URL for the external banking API.
BANK_API_URL=https://api.yourbank.com/v1

# PAYMENT_GATEWAY_URL: URL for the external payment gateway API.
PAYMENT_GATEWAY_URL=https://api.stripe.com/v1

# FINANCE_DISCORD_WEBHOOK: Discord webhook URL for financial notifications.
FINANCE_DISCORD_WEBHOOK=https://discord.com/api/webhooks/finance_webhook_url

# ------------------------------------------------------------------------------
# CTO Agent Service Configuration
# ------------------------------------------------------------------------------
# SYSTEM_LOG_PATH: Path to the system log file for monitoring.
SYSTEM_LOG_PATH=/var/log/agentic-system.log

# ERROR_THRESHOLD: Number of errors before spawning a debugger agent.
ERROR_THRESHOLD=5

# ------------------------------------------------------------------------------
# CMO Agent Service Configuration
# ------------------------------------------------------------------------------
# MARKETING_BUDGET: Monthly marketing budget in USD.
MARKETING_BUDGET=5000

# CAMPAIGN_APPROVAL_REQUIRED: Set to true if campaign approval is required.
CAMPAIGN_APPROVAL_REQUIRED=true

# ------------------------------------------------------------------------------
# Persistent Agent Layer Service Configuration
# ------------------------------------------------------------------------------
# PERSISTENT_AGENT_HEARTBEAT_INTERVAL: Heartbeat interval in milliseconds for persistent agents.
PERSISTENT_AGENT_HEARTBEAT_INTERVAL=30000

# PERSISTENT_AGENT_AUTO_RESTART: Set to true to enable auto-restart for persistent agents.
PERSISTENT_AGENT_AUTO_RESTART=true

# ------------------------------------------------------------------------------
# Spawn Manager Service Configuration
# ------------------------------------------------------------------------------
# SPAWN_MAX_CONCURRENT: Maximum number of concurrent spawned agents.
SPAWN_MAX_CONCURRENT=5

# SPAWN_TASK_TIMEOUT: Timeout in milliseconds for spawned agent tasks.
SPAWN_TASK_TIMEOUT=300000

# TASK_POLLING_INTERVAL: Polling interval in milliseconds for new tasks.
TASK_POLLING_INTERVAL=5000

# AGENT_CONFIG_DIR: Directory containing agent configuration files.
AGENT_CONFIG_DIR=/app/config/agents

# ------------------------------------------------------------------------------
# Translation Layer Service Configuration
# ------------------------------------------------------------------------------
# TRANSLATION_MODE: Translation provider to use (e.g., ollama, openai, google).
TRANSLATION_MODE=ollama

# TRANSLATION_MODEL: Model to use for translation (e.g., llama2, gpt-3.5-turbo, text-bison).
TRANSLATION_MODEL=llama2

# TRANSLATION_API_URL: API endpoint for the translation service.
TRANSLATION_API_URL=http://ollama:11434/api/generate

# ------------------------------------------------------------------------------
# Account Manager Service Configuration
# ------------------------------------------------------------------------------
# LLM_ACCOUNTS: Comma-separated list of LLM account details.
#               Format: provider:key:usage_limit
LLM_ACCOUNTS=

# ACCOUNT_ROTATION_INTERVAL: Interval in milliseconds for LLM account rotation.
ACCOUNT_ROTATION_INTERVAL=60000

# LLM_ACCOUNT_HEALTH_CHECK_INTERVAL: Interval in milliseconds for LLM account health checks.
LLM_ACCOUNT_HEALTH_CHECK_INTERVAL=300000

# ------------------------------------------------------------------------------
# Inter-service Communication URLs (Do not modify unless service names change)
# These URLs are constructed using the service names defined in docker-compose.yml
# and their respective internal Docker ports.
# ------------------------------------------------------------------------------
MEMORY_SYSTEM_URL=http://memory-system:${MEMORY_SYSTEM_PORT}
SPAWN_MANAGER_URL=http://spawn-manager:${SPAWN_MANAGER_PORT}
TRANSLATION_LAYER_URL=http://translation-layer:${TRANSLATION_LAYER_PORT}
ACCOUNT_MANAGER_URL=http://account-manager:${ACCOUNT_MANAGER_PORT}
SPAWN_AGENTS_URL=http://spawn-agents:${SPAWN_AGENTS_PORT}
