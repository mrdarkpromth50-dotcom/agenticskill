# --- Global Security Config ---
API_KEYS=your_api_key_1,your_api_key_2
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# --- Monitoring & Alerting ---
MONITORING_PORT=3008
METRICS_COLLECTION_INTERVAL=10000
ALERT_CHECK_INTERVAL=15000
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# --- Core Services ---
REDIS_URL=redis://redis:6379
VECTOR_DB_URL=http://chromadb:8000
VECTOR_DB_TYPE=chromadb
ANTIGRAVITY_PROXY_URL=http://antigravity-proxy:8080
OPENCLAW_URL=http://openclaw:18789

# --- Service Ports (Internal to Docker, exposed ports are in docker-compose.yml) ---
MEMORY_SYSTEM_PORT=3001
PERSISTENT_AGENT_LAYER_PORT=3002
SPAWN_MANAGER_PORT=3003
CEO_AGENT_PORT=3004
TRANSLATION_LAYER_PORT=3005
ACCOUNT_MANAGER_PORT=3006
SPAWN_AGENTS_PORT=3007

# --- CEO Agent Service ---
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
DISCORD_GUILD_ID=YOUR_DISCORD_GUILD_ID
DISCORD_CHANNEL_ID=YOUR_DISCORD_CHANNEL_ID
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# --- Persistent Agent Layer Service ---
PERSISTENT_AGENT_HEARTBEAT_INTERVAL=30000 # milliseconds (30 seconds)
PERSISTENT_AGENT_AUTO_RESTART=true

# --- Spawn Manager Service ---
SPAWN_MAX_CONCURRENT=5
SPAWN_TASK_TIMEOUT=300000 # milliseconds (5 minutes)
TASK_POLLING_INTERVAL=5000 # milliseconds (5 seconds)
AGENT_CONFIG_DIR=/app/config/agents

# --- Translation Layer Service ---
TRANSLATION_MODE=ollama # or openai, google, etc.
TRANSLATION_MODEL=llama2 # or gpt-3.5-turbo, text-bison, etc.
TRANSLATION_API_URL=http://ollama:11434/api/generate # or OpenAI API endpoint

# --- Account Manager Service ---
LLM_ACCOUNTS= # Comma-separated list of LLM account details (e.g., "provider:key:usage_limit,provider:key:usage_limit")
ACCOUNT_ROTATION_INTERVAL=60000 # milliseconds (1 minute)
LLM_ACCOUNT_HEALTH_CHECK_INTERVAL=300000 # milliseconds (5 minutes)

# --- Inter-service Communication URLs (used by other services to connect) ---
MEMORY_SYSTEM_URL=http://memory-system:${MEMORY_SYSTEM_PORT}
SPAWN_MANAGER_URL=http://spawn-manager:${SPAWN_MANAGER_PORT}
TRANSLATION_LAYER_URL=http://translation-layer:${TRANSLATION_LAYER_PORT}
ACCOUNT_MANAGER_URL=http://account-manager:${ACCOUNT_MANAGER_PORT}
SPAWN_AGENTS_URL=http://spawn-agents:${SPAWN_AGENTS_PORT}

# --- Database/Cache Ports (for direct connection if needed) ---
REDIS_PORT=6379
CHROMADB_PORT=8000
OLLAMA_PORT=11434 # If using Ollama for translation
